// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(uuid())
  username      String            @unique
  password      String            // bcrypt加密后的密码
  name          String            // 显示名称
  role          String            @default("admin")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  articleLocks  ArticleEditLock[]

  @@index([username])
}

model Article {
  id               String            @id @default(uuid())
  title            String
  author           String
  createdAt        DateTime          @default(now())
  importance       String            // 'low', 'medium', 'high'
  views            Int               @default(0)
  content          String            // 富文本内容（HTML）
  contentPlainText String            @default("")  // 纯文本内容，用于FTS5索引
  updatedAt        DateTime          @updatedAt
  editLock         ArticleEditLock?

  @@index([title])
  @@index([createdAt])
  @@index([author])
}

model ArticleEditLock {
  id            String   @id @default(uuid())
  articleId     String   @unique
  userId        String
  sessionId     String   // 浏览器会话ID，用于多标签页协调
  expiresAt     DateTime // 锁过期时间
  lastHeartbeat DateTime // 最后心跳时间
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([userId])
  @@index([expiresAt])
}

model SensitiveWord {
  id         String   @id @default(uuid())
  word       String   // 敏感词
  category   String   // 分类：politics, violence, pornography, advertisement, other
  level      String   // 级别：high(阻断发布), medium(强制替换), low(仅警告)
  strategy   String   // 策略：block, replace, warn
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([word])
  @@index([category])
  @@index([level])
  @@index([enabled])
  @@unique([word])
}

model BatchOperationLog {
  id              String   @id @default(uuid())
  operationType   String
  operatorId      String
  operatorName    String
  articleIds      String
  articleCount    Int
  params          String
  snapshots       String
  status          String
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  errorDetails    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reverted        Boolean  @default(false)
  revertedAt      DateTime?

  @@index([operationType])
  @@index([operatorId])
  @@index([createdAt])
  @@index([status])
}

model BackupRecord {
  id              String   @id @default(uuid())
  type            String   // manual, scheduled, snapshot
  status          String   // creating, completed, failed, restoring, restored
  filename        String
  fileSize        Int      @default(0)
  dbPath          String
  uploadsMetaJson String   @default("{}")
  articleCount    Int      @default(0)
  operatorId      String?
  operatorName    String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model BackupSchedule {
  id              String   @id @default(uuid())
  enabled         Boolean  @default(true)
  cronExpression  String   @default("0 2 * * *")
  retentionDays   Int      @default(7)
  retentionCount  Int      @default(10)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt

  @@index([key])
}
